{
  "name": "agent-testbench",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-native test environment for API workflows, auditable evidence, and quality gates.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build:frontend": "node control-plane/frontend/build.mjs",
    "demo:api-case": "node tools/examples/api-case-demo.mjs",
    "demo:services": "node tools/examples/demo-service-server.mjs",
    "guard:duplicates": "bash tools/guardrails/check_duplicate_code.sh",
    "release-check": "bash tools/release-check.sh",
    "release-check:mysql-real": "bash tools/smoke/mysql-real-store-release-check.sh",
    "release-check:mysql-real:preflight": "AGENT_TESTBENCH_REAL_MYSQL_RELEASE_DRY_RUN=1 bash tools/smoke/mysql-real-store-release-check.sh",
    "store:preflight:mysql": "bash tools/smoke/mysql-store-preflight.sh",
    "store:audit:mysql-goal": "bash tools/smoke/mysql-store-goal-audit.sh",
    "store:publish:mysql": "bash tools/smoke/mysql-store-publish-verified-env.sh",
    "store:restore:mysql": "bash tools/smoke/mysql-store-colleague-restore.sh",
    "smoke:api:mysql-store": "AGENT_TESTBENCH_DISABLE_SQLITE_STORE=1 node tools/smoke/mysql-store-api-smoke.mjs",
    "smoke:cli:sql-active": "AGENT_TESTBENCH_DISABLE_SQLITE_STORE=1 node tools/smoke/cli-active-store-smoke.mjs",
    "smoke:frontend": "AGENT_TESTBENCH_DISABLE_SQLITE_STORE=1 node tools/smoke/control-plane-smoke.mjs",
    "smoke:frontend:sql-active": "npm run smoke:frontend",
    "test:frontend": "node --test control-plane/frontend/src/*.test.mjs",
    "test": "go test ./..."
  },
  "devDependencies": {
    "@xyflow/react": "^12.10.2",
    "esbuild": "^0.28.0",
    "lucide-react": "^1.14.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
