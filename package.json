{
  "name": "open-test-sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first integration test sandbox for template-driven workflows, API cases, fixtures, and evidence.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build:frontend": "node control-plane/frontend/build.mjs",
    "demo:api-case": "node tools/examples/api-case-demo.mjs",
    "release-check": "bash tools/release-check.sh",
    "smoke:frontend": "node tools/smoke/control-plane-smoke.mjs",
    "smoke:frontend:pg-only": "OTSANDBOX_DISABLE_SQLITE_STORE=1 node tools/smoke/control-plane-smoke.mjs",
    "test:frontend": "node --test control-plane/frontend/src/*.test.mjs",
    "test": "go test ./..."
  },
  "devDependencies": {
    "@xyflow/react": "^12.10.2",
    "esbuild": "^0.28.0",
    "lucide-react": "^1.14.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
